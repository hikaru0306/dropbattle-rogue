// ドロプシア Firestore セキュリティルール
// デプロイ方法: Firebaseコンソール → Firestore Database → ルール タブに全文貼り付け → 公開
rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    // 管理者（開発者本人のGoogleアカウント）は全ユーザーの進捗を閲覧可能（admin.html用・書き込みは不可）
    function isAdmin() {
      return request.auth != null && request.auth.uid == "flFrnAuMykhkLrpxH5eeQSt5HPI2";
    }
    // 各ユーザーは自分のドキュメントのみ読み書き可（匿名ユーザーも request.auth を持つ）
    match /users/{uid} {
      allow read: if isAdmin();
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['v','updatedAt','svTime','clientVersion','linked','summary','progress','data'])
        && request.resource.data.v is int
        && request.resource.data.updatedAt is number
        && request.resource.data.clientVersion is string
        && request.resource.data.linked is bool
        // data: localStorageミラー。キー数を制限（実際のゲームは30個未満。肥大化・コスト攻撃対策）
        && request.resource.data.data is map
        && request.resource.data.data.size() < 100
        && request.resource.data.summary is string
        && request.resource.data.summary.size() < 500
        // progress: admin.html が表示に使うため形を固定（数値期待の場所に文字列/HTMLを入れさせない）
        && request.resource.data.progress is map
        && request.resource.data.progress.keys().hasOnly(['unlocked','clearedOmote','clearedUra','totalClears','totalUraClears','perChar'])
        && request.resource.data.progress.unlocked is int
        && request.resource.data.progress.clearedOmote is list
        && request.resource.data.progress.clearedUra is list
        && request.resource.data.progress.totalClears is int
        && request.resource.data.progress.totalUraClears is int
        && request.resource.data.progress.perChar is map;
    }
    // それ以外はすべて拒否
    match /{document=**} { allow read, write: if false; }
  }
}
